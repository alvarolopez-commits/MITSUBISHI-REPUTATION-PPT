{
  "annex_id": "mitsubishi_top_bottom_drivers",
  "title": "Drivers y barreras de los mejores y peores dealers Mitsubishi",
  "scope": {
    "brand": "Mitsubishi",
    "brand_id": 34,
    "period": {
      "from": "2025-12-25",
      "to": "2026-06-25",
      "inclusive": true
    },
    "dealer_selection": {
      "minimum_reviews": 50,
      "minimum_reviews_operator": "greater_than_or_equal",
      "eligible_dealers": 23
    },
    "qualitative_filter": {
      "minimum_mentions": 3,
      "minimum_mentions_operator": "greater_than_or_equal",
      "note": "Una mención es un fragmento categorizado de una review; no equivale necesariamente a una review única."
    }
  },
  "methodology": {
    "dealer_ranking_metric": "total_enps",
    "top_dealers_order": "descending",
    "bottom_dealers_order": "ascending",
    "enps_formula": "100 * (reviews_5_stars - reviews_1_star - reviews_2_stars - reviews_3_stars) / total_reviews",
    "four_star_reviews": "Pasivas: forman parte del denominador, pero no suman ni restan en el numerador.",
    "positive_driver_ranking": [
      "Mayor positive_rate",
      "En caso de empate, mayor mentions_total"
    ],
    "negative_barrier_ranking": [
      "Mayor mentions_negative",
      "En caso de empate, mayor negative_rate",
      "En caso de nuevo empate, mayor mentions_total"
    ],
    "positive_rate_formula": "mentions_positive / mentions_total * 100",
    "negative_rate_formula": "mentions_negative / mentions_total * 100"
  },
